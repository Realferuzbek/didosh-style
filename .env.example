# ── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # Server-only. Never expose to the browser.

# ── Admin Panel ─────────────────────────────────────────────────────────────
# Any strong password. Used to log in to /admin.
ADMIN_PASSWORD=

# ── JWT Auth ────────────────────────────────────────────────────────────────
# Random 32+ character secret for signing user login tokens.
# Generate with: openssl rand -base64 32
JWT_SECRET=

# ── Telegram Bot ────────────────────────────────────────────────────────────
# Get from @BotFather on Telegram after creating your bot.
TELEGRAM_BOT_TOKEN=
# Your bot username WITHOUT the @ symbol. Example: DidoshStyleBot
TELEGRAM_BOT_USERNAME=
# Webhook signature secret — set this when registering the webhook:
# https://api.telegram.org/bot<TOKEN>/setWebhook?url=<URL>&secret_token=<THIS_VALUE>
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# ── Eskiz SMS (Uzbekistan) ──────────────────────────────────────────────────
# Register at: https://eskiz.uz
# IMPORTANT: Set ESKIZ_ENABLED=true only after your MCHJ/YATT is registered
# and Eskiz has approved your credentials. Until then, leave it as false —
# the Telegram OTP flow handles all authentication.
ESKIZ_ENABLED=false
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# Approved sender name/ID from your Eskiz dashboard. Defaults to '4546'.
ESKIZ_SENDER=

# ── Site URL ────────────────────────────────────────────────────────────────
# Full deployed URL with no trailing slash.
# Example: https://didoshstyle.netlify.app
NEXT_PUBLIC_SITE_URL=
